{
  "name": "dark-souls-3-cheat-sheet",
  "version": "1.0.0",
  "private": true,
  "description": "Dev tooling for the DS3 Cheat Sheet. The site itself is static and needs no build step.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "validate": "node tools/validate.mjs",
    "serve": "node tests/server.mjs",
    "test": "playwright test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.3.3"
  },
  "lint-staged": {
    "*.{js,mjs,css,html,json,md,yml,yaml}": "prettier --ignore-unknown --write",
    "data/checklist.json": "node tools/validate.mjs"
  }
}
